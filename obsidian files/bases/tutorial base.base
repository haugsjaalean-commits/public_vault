filters:
  and:
    - file.folder != "obsidian files/templates"
    - file.tags.contains("object/tutorial")
views:
  - type: table
    name: Table
    order:
      - file.name
      - rating
      - subjects
      - YouTube link
    sort:
      - property: rating
        direction: DESC
    columnSize:
      note.rating: 90
